# GitHub Pages缓存配置

# 静态资源长期缓存（带哈希的文件）
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  Content-Encoding: br

# 字体文件长期缓存
/font/*
  Cache-Control: public, max-age=31536000, immutable
  Content-Encoding: br

# 图片长期缓存
*.webp
  Cache-Control: public, max-age=31536000, immutable

*.png
  Cache-Control: public, max-age=31536000, immutable

*.jpg
  Cache-Control: public, max-age=31536000, immutable

*.svg
  Cache-Control: public, max-age=31536000, immutable

# JS和CSS不缓存（确保内容更新）
*.js
  Cache-Control: public, max-age=0, must-revalidate
  Content-Encoding: br

*.css
  Cache-Control: public, max-age=0, must-revalidate
  Content-Encoding: br

# HTML文件不缓存（确保内容更新）
*.html
  Cache-Control: public, max-age=0, must-revalidate

# 根路径不缓存
/
  Cache-Control: public, max-age=0, must-revalidate

# 启用 Brotli 和 Gzip 压缩
/*
  Vary: Accept-Encoding
