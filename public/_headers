# GitHub Pages 缓存策略配置

# 启用 HTTP/2 和 HTTP/3 (通过 Cloudflare 等 CDN)
/*
  Alt-Svc: h3=":443"; ma=86400
  
# 静态资源 - 长期缓存（1年）
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  Content-Encoding: br

/font/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  Content-Encoding: br

/spine_assets/*
  Cache-Control: public, max-age=31536000, immutable
  Content-Encoding: br

/posts/*
  Cache-Control: public, max-age=86400

# HTML 文件 - 不缓存（总是获取最新）
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# 根路径
/
  Cache-Control: public, max-age=0, must-revalidate

# Service Worker - 不缓存
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

# 安全头部
/*
  # 防止点击劫持
  X-Frame-Options: DENY
  
  # 防止 MIME 嗅探
  X-Content-Type-Options: nosniff
  
  # Referrer 策略 - 保护隐私
  Referrer-Policy: strict-origin-when-cross-origin
  
  # 权限策略 - 禁用不需要的 API
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=()
  
  # HSTS - 强制 HTTPS
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  
  # CSP - 内容安全策略
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://v1.hitokoto.cn; media-src 'self'; frame-ancestors 'none'
