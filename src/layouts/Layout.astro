---
import '../styles/index.less'
import 'normalize.css'
import '../styles/vars.less'
import '../styles/icons.less'
import Splash from '../components/Splash.vue'
import Footer from '../components/Footer.vue'
import ToTop from '../components/ToTop.vue'
import '../store'

interface Props {
  title?: string
}

const { title = '其实你们都是柔情猫娘吧QAQ' } = Astro.props
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="其实你们都是柔情猫娘吧QAQ" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    
    <link rel="dns-prefetch" href="https://v1.hitokoto.cn" />
    <link rel="preconnect" href="https://v1.hitokoto.cn" crossorigin="" />
    <link rel="dns-prefetch" href="https://unpkg.com" />
    <link rel="preconnect" href="https://unpkg.com" crossorigin="" />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin="" />
    
    <link rel="preload" href="/font/Blueaka/Blueaka-04963599723c63b7.woff2" as="font" type="font/woff2" crossorigin="" />
    <link rel="preload" href="/font/Blueaka_Bold/Blueaka_Bold-0719faaf51e6146e.woff2" as="font" type="font/woff2" crossorigin="" />
    
    <link rel="stylesheet" href="https://unpkg.com/gitalk/dist/gitalk.css" />
    <script src="https://unpkg.com/gitalk/dist/gitalk.min.js" defer></script>
    
    <link rel="stylesheet" href="/font/Blueaka/Blueaka.css" />
    <link rel="stylesheet" href="/font/Blueaka_Bold/Blueaka_Bold.css" />
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui/dist/fancybox.css" />
    <script src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@4.0/dist/fancybox.umd.js"></script>
  </head>
  <body>
    <Splash client:load />
    
    <main style="min-height: 100vh">
      <slot />
    </main>
    
    <Footer client:load />
    <ToTop client:load />
  </body>
</html>
